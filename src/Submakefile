PROJECT_PATH = emc/usr_intf/qtemc

# The default target for building your project
../bin/qtemc: qmakefile ../lib/libnml.so.0
	cd ${PROJECT_PATH} && $(MAKE) -f Makefile install

# A rule to regenerate the Makefile using qmake
qmakefile: ${PROJECT_PATH}/qtemc.pro
	cd ${PROJECT_PATH} && $(QMAKE) -makefile qtemc.pro

TARGETS += ../bin/qtemc
